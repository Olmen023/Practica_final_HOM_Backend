# Servidor
PORT=3000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://localhost:27017/bildyapp

# JWT (heredado de la práctica intermedia)
JWT_SECRET=cambia-esto-en-produccion
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=cambia-esto-tambien
JWT_REFRESH_EXPIRES_IN=7d

# bcrypt
BCRYPT_SALT_ROUNDS=12

# Uploads (local fallback)
UPLOAD_MAX_SIZE_MB=5
UPLOAD_DIR=uploads/

# Cloudinary (para firmas y PDFs)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Nodemailer (código de verificación)
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=
SMTP_PASS=
MAIL_FROM="BildyApp <no-reply@bildyapp.local>"

# Slack (para errores 5XX)
SLACK_WEBHOOK_URL=
